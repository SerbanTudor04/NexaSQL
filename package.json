{
  "name": "nexasql",
  "version": "1.0.0",
  "description": "NexaSQL Enterprise Database IDE",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@guolao/vue-monaco-editor": "^1.4.8",
    "@lucide/vue": "^1.18.0",
    "@tanstack/vue-virtual": "^3.0.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.41.3",
    "chart.js": "^4.4.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-store": "^8.1.0",
    "keytar": "^7.9.0",
    "lucide-vue-next": "^0.344.0",
    "monaco-editor": "^0.45.0",
    "pg": "^8.11.3",
    "pinia": "^2.1.7",
    "radix-vue": "^1.9.0",
    "recharts": "^2.12.2",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.4.21",
    "vue-chartjs": "^5.3.1"
  },
  "optionalDependencies": {
    "oracledb": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/pg": "^8.11.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.18",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.nexasql.app",
    "productName": "NexaSQL",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
